{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "public": "dist/client",
  "functions": {
    "api/index.ts": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    {
      "source": "/dist/client/(.*)",
      "destination": "/dist/client/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/api"
    }
  ]
}
